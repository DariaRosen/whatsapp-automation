# Copy this file to .env.local and fill in your values.
#
# Webhook verification (required for receiving messages):
WHATSAPP_VERIFY_TOKEN=webicon_whatsapp_token
#
# MongoDB (required to store customer messages):
# MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
# DB_NAME=whatsapp
#
# Optional — for sending messages via the API later:
# WHATSAPP_ACCESS_TOKEN=your_permanent_or_temporary_token
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
