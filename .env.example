# Copy this file to .env.local and fill in your values.
#
# Webhook verification (required for receiving messages). Use the same value in Meta webhook form.
# WHATSAPP_VERIFY_TOKEN=<your-verify-token>
#
# MongoDB (required to store customer messages). Get connection string from MongoDB Atlas → Connect.
# MONGO_URL=<your-atlas-connection-string>
# DB_NAME=whatsapp
#
# Optional — for sending messages via the API later:
# WHATSAPP_ACCESS_TOKEN=your_permanent_or_temporary_token
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
